# Default chain id used when no wallet chain is active.
NUXT_PUBLIC_DEFAULT_CHAIN_ID=1

# Initial reader RPC shown in Settings. This can be overridden in the browser and is persisted locally.
NUXT_PUBLIC_DEFAULT_RPC=

# Dedicated Ethereum mainnet RPC for .eth ENS resolution when the active reader chain is not mainnet.
NUXT_PUBLIC_MAINNET_ENS_RPC=

# WalletConnect project id used by the inherited wallet stack.
NUXT_PUBLIC_EVM_WALLET_CONNECT_PROJECT_ID=

# Mainnet RPC list consumed by the inherited EVM layer.
NUXT_PUBLIC_EVM_CHAINS_MAINNET_RPCS=
