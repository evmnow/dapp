{
  "name": "dapp",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.0",
  "scripts": {
    "dev": "pnpm --filter @evm-now/contract-reader dev",
    "build": "pnpm -r --if-present build",
    "generate": "pnpm --filter @evm-now/contract-reader generate",
    "preview": "pnpm --filter @evm-now/contract-reader preview",
    "typecheck": "pnpm -r --if-present typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/luxon": "^3.7.0",
    "prettier": "^3.8.1"
  }
}
